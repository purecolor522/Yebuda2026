# ---- Supabase (production database + image storage) ----
# Leave BLANK for local dev → falls back to local data/*.json files + local /uploads disk.
# Fill these in (Project Settings → API) to switch the live site to Supabase.
#   SUPABASE_URL          : Project URL, e.g. https://abcdxyz.supabase.co
#   SUPABASE_SERVICE_KEY  : the "service_role" secret key (server-only, NEVER expose to browser)
#   SUPABASE_BUCKET       : Storage bucket name for product images (default product-images)
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_BUCKET=product-images

# ---- Server ----
PORT=3000
# Public HTTPS URL — ONLY set this on production with a real domain.
# Leave empty for local dev / testing. Server will auto-derive from request host.
APP_BASE_URL=

# ---- Admin access (員工：看到訂單 + 商品) ----
# CHANGE THESE BEFORE DEPLOYING.
ADMIN_PASSWORD=yebuda2026
ADMIN_SECRET=please-change-to-a-long-random-string

# ---- Owner access (老闆：看到進貨/庫存/帳務) ----
# 用不同密碼登入 /owner，員工不會知道也進不去
OWNER_PASSWORD=yebuda-owner-2026
OWNER_SECRET=please-change-this-too

# ---- AI image classification (Gemini) ----
# Get a FREE key at https://aistudio.google.com/apikey
# Free tier: Gemini 2.5 Flash — 15 requests/min, 1500 requests/day, no credit card needed.
# Without this key, the "🤖 AI 辨識" button in product-edit will show a friendly error.
GEMINI_API_KEY=

# ---- ECPay (綠界) ----
# Default ships with test-mode (stage) credentials that work out of the box.
# For production, sign up at https://vendor.ecpay.com.tw/ and paste your merchant credentials here.
ECPAY_ENV=stage                      # "stage" or "production"
ECPAY_MERCHANT_ID=3002607            # 金流（信用卡 / ATM）測試帳號
ECPAY_HASH_KEY=pwFHCqoQZGmho4w6
ECPAY_HASH_IV=EkRm7iFT261dpevs
# 物流（超商取貨地圖）— 留空使用 C2C 沙盒 2000933
# 上線時請到 https://logistics.ecpay.com.tw/ 申請物流帳號並填入此處
ECPAY_LOGISTICS_MERCHANT_ID=

# ---- Email Notification ----
# SMTP_USER: Your Gmail address
# SMTP_PASS: Google App Password (16 characters)
# NOTIFICATION_EMAIL: Where you want to receive the new order emails
SMTP_USER=purecolor522@gmail.com
SMTP_PASS=hrtl sbzc ttse mvyo
NOTIFICATION_EMAIL=purecolor522@gmail.com

